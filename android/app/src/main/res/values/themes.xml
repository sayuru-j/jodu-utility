<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Jodu" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/fg</item>
        <item name="colorOnPrimary">@color/bg</item>
        <item name="colorSecondary">@color/muted</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/fg</item>
        <item name="android:textColorSecondary">@color/muted</item>
    </style>

    <style name="Widget.Jodu.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
    </style>

    <style name="Widget.Jodu.Button.Solid" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/fg</item>
        <item name="android:textColor">@color/bg</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.Jodu.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/line</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/fg</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
</resources>
